# ── Required ──────────────────────────────────────────────────────────────────
API_ID=                     # From https://my.telegram.org
API_HASH=                   # From https://my.telegram.org
BOT_TOKEN=                  # From @BotFather
OWNER_ID=                   # Your Telegram user ID (integer)
ASSISTANT_SESSION=          # Run: python genstring.py  to generate this
MONGO_URI=                  # e.g. mongodb+srv://user:pass@cluster.mongodb.net/jatt

# ── Optional ──────────────────────────────────────────────────────────────────
LOG_GROUP_ID=               # Private group ID — bot sends startup/error logs here
SUDO_USERS=                 # Comma-separated user IDs with sudo access, e.g. 123,456
OWNER_CHANNEL=              # https://t.me/yourchannel  (shown on /start button)
SUPPORT_GROUP=              # https://t.me/yoursupport  (shown on /start button)
UPDATE_CHANNEL=             # https://t.me/yourupdates  (shown on /start button)
START_IMAGE_URL=            # URL of banner image shown with /start in DMs
MAINTENANCE_MODE=false      # true = only OWNER_ID/SUDO_USERS can use the bot
